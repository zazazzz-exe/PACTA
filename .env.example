# Pacta — environment variables
#
# Set these in the host's environment (Vercel: Project Settings > Environment
# Variables) or, for local `vercel dev`, copy this file to `.env` and fill it in.
# NEVER commit real values or expose any of these to client code. None of these
# are VITE_-prefixed, so none are bundled into the frontend.

# --- AI Risk Lens (/api/risk-lens) ---
# Server-side call to the Google Gemini API. Server-only.
GEMINI_API_KEY=

# --- KYC identity layer (/api/kyc-*) ---
# Supabase project (service-role key — full access; server-only, never in the client)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# Optional, TEST-ONLY: the anon key is NOT used by the app (access is fully
# server-mediated). Set it only to run the RLS deny-by-default integration test.
SUPABASE_ANON_KEY=

# Signs the short-lived session cookie issued after wallet-ownership proof (32+ random bytes)
SESSION_JWT_SECRET=

# HMAC key used to hash gov ID / name for dedup (keyed hash; never store plaintext)
KYC_HASH_SECRET=

# KYC provider selection. 'mock' = built-in sandbox; 'didit' = Didit (hosted).
KYC_PROVIDER=mock
# Used by the mock provider's webhook signature only.
KYC_WEBHOOK_SECRET=

# --- Didit (set KYC_PROVIDER=didit to use) ---
# From the Didit Business Console (https://business.didit.me):
#   Settings > API & Webhooks  -> API key + webhook secret
#   Workflows > (create one)   -> workflow id
DIDIT_API_KEY=
DIDIT_WORKFLOW_ID=
DIDIT_WEBHOOK_SECRET=
# DIDIT_BASE_URL=https://verification.didit.me   # optional override
# APP_URL=https://your-app.example.com           # optional: forces the browser return URL
